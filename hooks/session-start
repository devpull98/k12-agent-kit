#!/usr/bin/env bash
# Inject framework context vào session khi bắt đầu.
# Nguồn cấu hình duy nhất: project-context.yaml.
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

CONFIG_FILE="project-context.yaml"
STACK=""
TEST_RUNNER=""
QC_STACK=""

# Đọc 1 scalar top-level từ project-context.yaml, cắt inline comment (# ...),
# trim khoảng trắng và bỏ dấu " bao quanh (nếu có).
cfgval() {
  grep -E "^$1:" "$ROOT/project-context.yaml" 2>/dev/null \
    | head -1 | sed "s/^$1:[[:space:]]*//; s/[[:space:]]*#.*$//; s/[[:space:]]*$//" \
    | tr -d '\r' | sed 's/^"\(.*\)"$/\1/'
}

if [[ -f "$ROOT/project-context.yaml" ]]; then
  STACK=$(cfgval stack)
  TEST_RUNNER=$(cfgval test_runner)
  QC_STACK=$(cfgval qc_stack)
else
  CONFIG_FILE="(chưa có project-context.yaml — copy từ kit root và điền stack:)"
fi

AGENTS_CONTENT=$(cat "$ROOT/AGENTS.md")

# Stack rules check
STACK_STATUS=""
if [[ -n "$STACK" ]]; then
  ARCH="$ROOT/rules/$STACK/architecture.mdc"
  TEST_PAT="$ROOT/rules/$STACK/test-patterns.mdc"
  if [[ -f "$ARCH" && -f "$TEST_PAT" ]]; then
    STACK_STATUS="Stack rules: OK (rules/$STACK/)"
  else
    MISSING=""
    [[ ! -f "$ARCH" ]] && MISSING="${MISSING}architecture.mdc "
    [[ ! -f "$TEST_PAT" ]] && MISSING="${MISSING}test-patterns.mdc "
    STACK_STATUS="Stack rules: MISSING ($MISSING) — copy từ rules/_template/ và tạo rules/$STACK/"
  fi
else
  STACK_STATUS="Stack: chưa cấu hình — tạo project-context.yaml với stack:"
fi

# Principles
PRINCIPLES=""
if [[ -f "$ROOT/docs/principles.md" ]]; then
  PRINCIPLES="Project principles: docs/principles.md (MUST follow)"
fi

CANONICAL="Canonical flow: workflows/canonical-flow.md"
GOVERNANCE="Governance: chạy scripts/governance-check.sh trước merge"

CONTEXT="Stack: ${STACK:-unset} | Config: $CONFIG_FILE"
[[ -n "$TEST_RUNNER" ]] && CONTEXT="$CONTEXT | Test runner: $TEST_RUNNER"
[[ -n "$QC_STACK" ]] && CONTEXT="$CONTEXT | QC stack: $QC_STACK"
CONTEXT="$CONTEXT

$STACK_STATUS
$PRINCIPLES
$CANONICAL
$GOVERNANCE

$AGENTS_CONTENT"

if command -v jq >/dev/null 2>&1; then
  jq -n --arg ctx "$CONTEXT" \
    '{hookSpecificOutput: {hookEventName: "SessionStart", additionalContext: $ctx}}'
else
  ESCAPED=$(printf '%s' "$CONTEXT" | sed 's/"/\\"/g' | tr '\n' ' ')
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$ESCAPED"
fi
