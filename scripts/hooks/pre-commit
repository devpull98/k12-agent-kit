#!/usr/bin/env bash
# Git hook: pre-commit
# Chạy các kiểm tra tĩnh độc lập với commit message (như Stack Rules).
#
# Cài đặt:
#   bash scripts/hooks/install-hooks.sh

set -euo pipefail

ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
cd "$ROOT"

if [[ "${GOVERNANCE_SKIP:-}" == "1" ]]; then
  exit 0
fi

echo "=== Git Pre-Commit Check ==="

# Chạy kiểm tra Stack Rules
if [[ -f scripts/validate-stack.sh ]]; then
  if ! bash scripts/validate-stack.sh; then
    echo "❌ ERROR: Stack rules validation failed."
    echo "   Vui lòng chuẩn bị rules stack của dự án trước khi commit."
    exit 1
  fi
fi

exit 0
